# Application settings (optional - defaults work for local dev)

# --- Community Edition (recommended for public / OSS deploy) ---
# APP_EDITION=community
# APP_ENFORCEMENT_MODE=monitor
# APP_CORRELATION_ENGINE_ENABLED=false
# APP_EXECUTIVE_METRICS_ENABLED=false
# APP_REPORTS_ENABLED=false
# APP_PLAYBOOKS_ENABLED=false
# APP_LEARNING_LOOP_ENABLED=false
# enforce mode is rejected at startup when APP_EDITION=community

# --- Enterprise (default when APP_EDITION is unset) ---
# APP_EDITION=enterprise

# APP_RULES_PATH=app/rules/default_yml_rule.yml
# APP_LOG_LEVEL=INFO
# APP_RATE_LIMIT=100/minute
# APP_RULES_CACHE_TTL_SECONDS=60

# Correlation Engine integration (off by default)
# APP_CORRELATION_ENGINE_ENABLED=false
# APP_CORRELATION_ENGINE_URL=http://localhost:8100
# APP_CORRELATION_ENGINE_SECRET=change-me-in-prod

# Executive Dashboard - off by default. Flip the kill switch to
# create the SQLite rollup file lazily and start the background aggregator.
# APP_EXECUTIVE_METRICS_ENABLED=false
# APP_EXECUTIVE_METRICS_DB_PATH=data/executive_metrics.sqlite
# APP_EXECUTIVE_AGGREGATOR_INTERVAL_SECONDS=300
# APP_EXECUTIVE_RETENTION_5M_HOURS=48
# APP_EXECUTIVE_RETENTION_1H_DAYS=35
# APP_EXECUTIVE_RETENTION_1D_DAYS=400

# Phase 4 Learning Loop - off by default. The outcome store accepts
# labels and the refiner proposes rule changes for human review. See
# docs/LEARNING_LOOP.md.
# APP_OUTCOME_STORE_PATH=data/learning_outcomes.sqlite
# APP_OUTCOME_INGEST_SECRET=change-me-in-prod
# APP_LEARNING_LOOP_ENABLED=false
# APP_LEARNING_LOOP_AUTO_APPLY=false
# APP_LEARNING_LOOP_MIN_SAMPLES=50
# APP_LEARNING_LOOP_FP_THRESHOLD=0.30
# APP_LEARNING_LOOP_HEALTHY_FP_CEILING=0.05
# APP_LEARNING_LOOP_SCHEDULE_SECONDS=3600

# Phase 4 Reporting Automation - persistent weekly reports + /reports API.
# The /reports API and its index are on by default. The weekly scheduler
# is opt-in (default off). See docs/REPORTING.md.
# APP_REPORTS_ENABLED=true
# APP_REPORT_STORE_PATH=data/reports
# APP_REPORT_INDEX_PATH=data/reports.sqlite
# APP_REPORT_SCHEDULER_ENABLED=false
# APP_REPORT_SCHEDULE_WEEKLY_WEEKDAY=0
# APP_REPORT_SCHEDULE_WEEKLY_HOUR=6
# APP_REPORT_SCHEDULER_TICK_SECONDS=60
# APP_REPORT_RETENTION_DAYS=90
# APP_REPORT_DEFAULT_KINDS=executive_pdf_7d,executive_csv_7d,portfolio_rollup_pdf

# Optional branding for the executive KPI PDF cover. Empty disables the
# brand block. Logo files larger than report_branding_logo_max_bytes
# are ignored so a misconfigured path cannot exhaust memory.
# APP_REPORT_BRANDING_COMPANY_NAME=Acme Corp
# APP_REPORT_BRANDING_LOGO_PATH=/etc/valo/branding/logo.png
# APP_REPORT_BRANDING_LOGO_MAX_BYTES=4194304
