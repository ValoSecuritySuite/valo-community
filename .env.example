# Valo Community Edition configuration (all variables use the APP_ prefix)

# Enforcement: monitor (log and annotate) or off. Enforce mode is not supported.
# APP_ENFORCEMENT_MODE=monitor

# APP_RULES_PATH=app/rules/default_yml_rule.yml
# APP_LOG_LEVEL=INFO
# APP_RATE_LIMIT=100/minute
# APP_RULES_CACHE_TTL_SECONDS=60

# OpenAI-compatible upstream for /v1/proxy/chat/completions
# APP_PROXY_UPSTREAM_URL=https://api.openai.com/v1/chat/completions
# APP_PROXY_REQUEST_TIMEOUT_SECONDS=60

# Optional correlation, executive, reporting, and learning modules are disabled
# in Community Edition and cannot be enabled via configuration.
